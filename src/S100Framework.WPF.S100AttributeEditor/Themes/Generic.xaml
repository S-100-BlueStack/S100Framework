<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"   
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:local="clr-namespace:S100Framework.WPF"
    xmlns:localcontrols="clr-namespace:S100Framework.WPF.Controls"
    xmlns:converters="clr-namespace:S100Framework.WPF.Converters"
    xmlns:validation="clr-namespace:S100Framework.WPF.Validation"
    xmlns:extensions="clr-namespace:ArcGIS.Desktop.Extensions;assembly=ArcGIS.Desktop.Extensions">

    <ResourceDictionary.MergedDictionaries>
        <extensions:DesignOnlyResourceDictionary Source="pack://application:,,,/ArcGIS.Desktop.Framework;component\Themes\Default.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    <converters:AttributeBindingDefinitionConverter x:Key="AttributeBindingDefinitionConverter"/>
    <converters:EnumSourceConverter x:Key="EnumSourceConverter"/>
    <converters:SelectedObjectSourceConverter x:Key="SelectedObjectSourceConverter"/>

    <Style x:Key="DeleteComplexAttributeIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Width="14" Height="14">
                        <Path x:Name="Icon" Fill="#E53935" Data="M7,0 A7,7 0 1 1 7,14 A7,7 0 1 1 7,0 Z"/>
                        <Path x:Name="X" Fill="White" Data="M4.02,3.11 L7,6.06 L9.96,3.11 L10.89,4.02 L7.93,7 L10.89,9.96 L9.96,10.89 L7,7.93 L4.02,10.89 L3.11,9.96 L6.06,7 L3.11,4.02 Z"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Icon" Property="Fill" Value="#D32F2F"/>
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Icon" Property="Fill" Value="#B71C1C"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Icon" Property="Fill" Value="#FFCCCCCC"/>
                            <Setter TargetName="X" Property="Fill" Value="#FFEEEEEE"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Visibility" Value="Visible"/>
        
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DockPanel, AncestorLevel=1}}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DeleteSimpleAttributeIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Background" Value="white"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Width="14" Height="14">
                        <Path x:Name="Icon" Fill="#E53935" Data="M7,0 A7,7 0 1 1 7,14 A7,7 0 1 1 7,0 Z"/>
                        <Path x:Name="X" Fill="White" Data="M4.02,3.11 L7,6.06 L9.96,3.11 L10.89,4.02 L7.93,7 L10.89,9.96 L9.96,10.89 L7,7.93 L4.02,10.89 L3.11,9.96 L6.06,7 L3.11,4.02 Z"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Icon" Property="Fill" Value="#D32F2F"/>
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Icon" Property="Fill" Value="#B71C1C"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Icon" Property="Fill" Value="#FFCCCCCC"/>
                            <Setter TargetName="X" Property="Fill" Value="#FFEEEEEE"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Visibility" Value="Hidden"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DockPanel, AncestorLevel=1}}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>


    <Style x:Key="ButtonLikeComboBox" TargetType="ComboBox">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" Background="Transparent" BorderBrush="Transparent" BorderThickness="{TemplateBinding BorderThickness}" Focusable="False" 
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" ClickMode="Press">
                            <Grid Width="18" Height="18">
                                <Grid.LayoutTransform>
                                    <ScaleTransform ScaleX="0.777" ScaleY="0.777"/>
                                </Grid.LayoutTransform>

                                <Path Fill="#4CAF50" Data="M9,0 A9,9 0 1 1 9,18 A9,9 0 1 1 9,0 Z" />
                                <Path Fill="White" Data="M8,4 H10 V8 H14 V10 H10 V14 H8 V10 H4 V8 H8 Z" />
                            </Grid>
                        </ToggleButton>

                        <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Slide">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- VISUAL STATES -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ToggleButton" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem" x:Key="AttributeBindingButtonLikeComboBoxItemStyle">
        <!-- Bind IsEnabled to your model -->
        <Setter Property="IsEnabled">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource AttributeBindingDefinitionConverter}">
                    <Binding/>
                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Expander}"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>

        <!-- Default foreground -->
        <Setter Property="Foreground" Value="Black" />

        <!-- Gray out disabled items -->
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#888" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Template for Strings -->
    <DataTemplate x:Key="StringEditorTemplate">
        <xctk:WatermarkTextBox Text="{Binding value}" Watermark="[UNKNOWN]"/>
    </DataTemplate>

    <!-- Templates for Numbers -->
    <DataTemplate x:Key="IntegerEditorTemplate">
        <xctk:IntegerUpDown Value="{Binding value}" Watermark="[UNKNOWN]" ShowButtonSpinner="False" ParsingNumberStyle="Integer"/>
    </DataTemplate>
    <DataTemplate x:Key="DecimalEditorTemplate">
        <xctk:DecimalUpDown Value="{Binding value}" Watermark="[UNKNOWN]" ShowButtonSpinner="False" ParsingNumberStyle="Any"/>
    </DataTemplate>

    <!-- Templates for Date/Time -->
    <DataTemplate x:Key="DateTimeEditorTemplate">
        <xctk:DateTimePicker 
            Value="{Binding value}" 
            Format="Custom" 
            FormatString="yyyy-MM-dd HH:mm" 
            Watermark="[yyyy-MM-dd HH:mm]" 
            ShowButtonSpinner="False"
            ShowDropDownButton="True" TimePickerVisibility="Visible"/>
    </DataTemplate>
    <DataTemplate x:Key="DateOnlyEditorTemplate">
        <xctk:DateTimePicker 
            Value="{Binding value}" 
            Format="Custom" 
            FormatString="yyyy-MM-dd" 
            Watermark="[yyyy-MM-dd]" 
            ShowButtonSpinner="False"
            ShowDropDownButton="True" TimePickerVisibility="Collapsed"/>
    </DataTemplate>
    <DataTemplate x:Key="TimeEditorTemplate">
        <xctk:DateTimeUpDown Value="{Binding value}" Format="Custom" FormatString="HH:mm" Watermark="[HH:mm]" ShowButtonSpinner="False"/>
    </DataTemplate>
    <DataTemplate x:Key="TruncatedDateEditorTemplate">
        <xctk:WatermarkTextBox Watermark="[UNKNOWN]">
            <xctk:WatermarkTextBox.Text>
                <Binding Path="value" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validation:TruncatedDateRule />
                    </Binding.ValidationRules>
                </Binding>
            </xctk:WatermarkTextBox.Text>
        </xctk:WatermarkTextBox>
    </DataTemplate>


    <!-- Template for Booleans -->
    <DataTemplate x:Key="BooleanEditorTemplate">
        <CheckBox IsChecked="{Binding value}" VerticalAlignment="Center" IsThreeState="True" Style="{DynamicResource Esri_CheckboxToggleSwitch}"/>
    </DataTemplate>

    <DataTemplate x:Key="EnumEditorTemplate">
        <ComboBox ItemsSource="{Binding {}, Converter={StaticResource EnumSourceConverter}}"
                  DisplayMemberPath="label"
                  SelectedValue="{Binding value}"
                  SelectedValuePath="code"
                  IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBooleanConverter}}"                     
                  Padding="2"/>
        <!--Background="{DynamicResource Esri_BackgroundPressedBrush}" 
                  Foreground="{DynamicResource Esri_TextMenuBrush}"/>-->
    </DataTemplate>

    <DataTemplate x:Key="FeatureBindingEditorTemplate">
        <ComboBox ItemsSource="{Binding items}" 
                  SelectedValue="{Binding value}"                  
                  Padding="2"/>
        <!--Background="{DynamicResource Esri_BackgroundPressedBrush}" 
                  Foreground="{DynamicResource Esri_TextMenuBrush}"/>-->
    </DataTemplate>

    <!--<DataTemplate x:Key="ComplexEditorTemplate">
    <local:S100AttributeEditor SelectedObject="{Binding {}, Converter={StaticResource SelectedObjectSourceConverter}}" />
</DataTemplate>-->

    <local:PropertyTemplateSelector x:Key="PropSelector" 
                                    TextEditorTemplate="{StaticResource StringEditorTemplate}"
                                    DateOnlyEditorTemplate="{StaticResource DateOnlyEditorTemplate}"
                                    DateTimeEditorTemplate="{StaticResource DateTimeEditorTemplate}"
                                    TimeEditorTemplate="{StaticResource TimeEditorTemplate}"
                                    TruncatedDateEditorTemplate="{StaticResource TruncatedDateEditorTemplate}"
                                    RealEditorTemplate="{StaticResource DecimalEditorTemplate}"                                    
                                    BooleanEditorTemplate="{StaticResource BooleanEditorTemplate}"
                                    IntegerEditorTemplate="{StaticResource IntegerEditorTemplate}"
                                    EnumEditorTemplate="{StaticResource EnumEditorTemplate}"
                                    FeatureBindingEditorTemplate="{StaticResource FeatureBindingEditorTemplate}"/>

    <Style TargetType="{x:Type localcontrols:DropdownButton}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localcontrols:DropdownButton}">
                    <Grid>
                        <!-- Main button -->
                        <ToggleButton x:Name="PART_Button" Content="{TemplateBinding Content}" IsChecked="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Background="#EEE" BorderBrush="#888" BorderThickness="1" Padding="6,3" HorizontalContentAlignment="Left"/>
                        <!-- Popup -->
                        <Popup x:Name="PART_Popup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" IsOpen="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" PlacementTarget="{Binding ElementName=PART_Button}">
                            <Border Background="White" BorderBrush="#888" BorderThickness="1" CornerRadius="3" Padding="4">
                                <ContentPresenter Content="{TemplateBinding DropdownContent}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
