<UserControl x:Class="S100Framework.WPF.PropertyGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:S100Framework.WPF.Converters"
             xmlns:local="clr-namespace:S100Framework.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/S100Framework.WPF.S100AttributeEditor;component/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>-->
    <StackPanel>
        <DockPanel Grid.Row="0" LastChildFill="True" Background="#F0EEF1">
            <StackPanel DockPanel.Dock="Right"  Orientation="Horizontal">
                <ComboBox
                    Style="{StaticResource ButtonLikeComboBox}"
                    ItemContainerStyle="{StaticResource ButtonLikeComboBoxItemStyle}"
                    ItemsSource="{Binding SelectedObject.attributeBindingsCatalogue, RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}}"                          
                    DisplayMemberPath="attribute">
                    <i:Interaction.Behaviors>
                        <local:SelectionChangedBehavior Command="{Binding CreateAttributeCommand, RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}}" />
                    </i:Interaction.Behaviors>
                </ComboBox>
                <Button Style="{StaticResource DeleteIconButtonStyle}">
                    <i:Interaction.Behaviors>
                        <local:ClickedBehavior Command="{Binding DeleteAttributeCommand, RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}}" Parameter="{Binding}" Parent="{Binding RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" />
                    </i:Interaction.Behaviors>
                </Button>
            </StackPanel>
            <TextBlock DockPanel.Dock="Left" Text="{Binding SelectedObject.code, RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}}" FontWeight="Bold" VerticalAlignment="Center" />
        </DockPanel>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding SelectedObject.attributeBindings, RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}}"
                      ItemTemplateSelector="{StaticResource ItemControlSelector}"/>
    </StackPanel>
        <!--</Grid>-->

</UserControl>
