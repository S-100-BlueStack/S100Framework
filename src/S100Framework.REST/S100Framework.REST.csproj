<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>

		<PackageId>S100Framework.REST</PackageId>
		<Version>1.5.0</Version>

		<Authors>S-100 BlueStack</Authors>
		<Company>S-100 BlueStack</Company>
		<Product>S100Framework</Product>

		<Description>.NET library for reading, editing, bulk-loading, and analyzing Esri Feature Services through the ArcGIS REST API and exposing geometry data through NetTopologySuite, without ArcGIS SDK dependencies.</Description>

		<PackageTags>ArcGIS;Esri;FeatureService;REST;NetTopologySuite;Geometry;S-100</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseExpression>MIT-0</PackageLicenseExpression>
		<PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>

		<RepositoryUrl>https://github.com/S-100-BlueStack/S100Framework</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://github.com/S-100-BlueStack/S100Framework</PackageProjectUrl>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>

		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>

		<PackageReleaseNotes>
			- Added async queryAnalytic submission support.
			- Added queryAnalytic status polling and result retrieval.
			- Added WaitForQueryAnalyticCompletionAsync convenience methods.
			- Added QueryAnalyticWaitOptions and QueryAnalyticJobStatus models.
			- Added async queryAnalytic capability mapping through FeatureLayerCapabilities.SupportsAsyncQueryAnalytic.
			- Hardened queryAnalytic job status handling for Esri job-status values such as esriJobSubmitted, esriJobExecuting, esriJobSucceeded, esriJobFailed, esriJobTimedOut, and esriJobCancelled.
			- Updated README documentation for synchronous and asynchronous queryAnalytic workflows.
		</PackageReleaseNotes>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.5" />
		<PackageReference Include="Microsoft.Extensions.Http" Version="10.0.5" />
		<PackageReference Include="NetTopologySuite" Version="2.6.0" />
	</ItemGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>